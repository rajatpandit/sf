{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Tasks Kanban Board",
  "type": "object",
  "properties": {
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["todo", "in_progress", "in_review", "done"]
          },
          "assigned_role": { "type": "string" },
          "context_slice": { "type": "string" },
          "required_mcps": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": ["id", "title", "status", "assigned_role", "context_slice"],
        "additionalProperties": false
      }
    }
  },
  "required": ["tasks"],
  "additionalProperties": false
}
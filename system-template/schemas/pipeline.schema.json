{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Agent Pipeline Configuration",
  "type": "object",
  "properties": {
    "version": { "type": "string" },
    "playbook": { "type": "string" },
    "constitution": { "type": "string", "enum": ["strict", "lean"] },
    "global_settings": {
      "type": "object",
      "properties": {
        "agent_tool": { "type": "string", "enum": ["pi", "opencode", "gemini"] },
        "require_approval": {
          "type": "object",
          "additionalProperties": { "type": "boolean" }
        },
        "max_retries": { "type": "integer", "minimum": 0 },
        "memory": {
          "type": "object",
          "properties": {
            "max_events_before_compress": { "type": "integer", "minimum": 1 }
          },
          "required": ["max_events_before_compress"]
        }
      },
      "required": ["max_retries", "memory"]
    },
    "model_tiering": {
      "type": "object",
      "properties": {
        "reasoning": { "type": "string" },
        "fast": { "type": "string" },
        "local": { "type": "string" }
      },
      "required": ["reasoning", "fast"]
    }
  },
  "required": ["version", "playbook", "constitution", "global_settings", "model_tiering"]
}
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MCP Configuration",
  "type": "object",
  "additionalProperties": {
    "type": "object",
    "properties": {
      "transport": { "type": "string", "enum": ["stdio", "sse"] },
      "command": { "type": "string" },
      "args": {
        "type": "array",
        "items": { "type": "string" }
      },
      "url": { "type": "string", "format": "uri" },
      "env": {
        "type": "object",
        "additionalProperties": { "type": "string" }
      },
      "headers": {
        "type": "object",
        "additionalProperties": { "type": "string" }
      }
    },
    "required": ["transport"]
  }
}